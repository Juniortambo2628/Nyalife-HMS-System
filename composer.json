{
    "name": "nyalife/hms",
    "description": "Nyalife Hospital Management System - custom MVC PHP system",
    "type": "project",
    "require": {
        "php": "^8.1",
        "nikic/fast-route": "^1.3",
        "symfony/http-foundation": "^6.4",
        "symfony/var-dumper": "^6.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "cakephp/console": "^4.6",
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "*",
        "codeception/module-phpbrowser": "*",
        "doctrine/dbal": "^3.6",
        "doctrine/migrations": "^3.6",
        "friendsofphp/php-cs-fixer": "3.40",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.8",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-doctrine": "^1.3",
        "phpunit/phpunit": "^9.6",
        "rector/rector": "^1.2",
        "roave/security-advisories": "dev-latest",
        "robmorgan/phinx": "^0.13",
        "squizlabs/php_codesniffer": "^3.7",
        "symfony/stopwatch": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\Web\\": "includes/controllers/web/",
            "App\\Controllers\\Api\\": "includes/controllers/api/",
            "App\\Models\\": "includes/models/",
            "App\\Core\\": "includes/core/"
        },
        "files": [
            "config.php",
            "constants.php",
            "config/database.php",
            "functions.php",
            "validation_functions.php",
            "id_generator.php",
            "modal_functions.php",
            "includes/db_utils.php"
        ]
    },
    "scripts": {
        "post-install-cmd": [
            "@composer dump-autoload -o"
        ],
        "post-update-cmd": [
            "@composer dump-autoload -o"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
