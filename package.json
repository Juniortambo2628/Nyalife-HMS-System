{
  "name": "nyalife-hms-system",
  "version": "1.0.0",
  "description": "Nyalife Hospital Management System - Asset bundling and build tools",
  "scripts": {
    "build": "cross-env APP_PATH= webpack --mode production",
    "build:dev": "cross-env APP_PATH=/Nyalife-HMS-System webpack --mode development",
    "build:analyze": "cross-env ANALYZE=true APP_PATH= webpack --mode production",
    "dev": "cross-env APP_PATH=/Nyalife-HMS-System webpack --mode development --watch",
    "build:css": "postcss assets/css/*.css -d assets/dist/css --map",
    "build:js": "cross-env APP_PATH= webpack --mode production",
    "watch": "cross-env APP_PATH=/Nyalife-HMS-System webpack --mode development --watch",
    "lint:css": "stylelint 'assets/css/**/*.css'",
    "lint:js": "eslint assets/js/**/*.js",
    "lint": "npm run lint:js && npm run lint:css",
    "test": "echo \"No JS tests yet\" && exit 0"
  },
  "keywords": [
    "hms",
    "hospital-management",
    "php",
    "mvc"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "compression-webpack-plugin": "^10.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "cypress": "^15.7.0",
    "eslint": "^8.52.0",
    "glob": "^10.3.10",
    "jest": "^30.2.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.6.2",
    "purgecss-webpack-plugin": "^5.0.0",
    "style-loader": "^3.3.3",
    "stylelint": "^15.11.0",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bootstrap": "^5.3.2",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "clipboard": "^2.0.11",
    "crypto-js": "^4.2.0",
    "datatables.net": "^1.13.7",
    "datatables.net-bs5": "^1.13.7",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.0",
    "dropzone": "^6.0.0-beta.2",
    "fullcalendar": "^6.1.10",
    "fuse.js": "^7.1.0",
    "jquery": "^3.7.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.4",
    "qrcode": "^1.5.4",
    "quill": "^2.0.3",
    "select2": "^4.1.0-rc.0",
    "sweetalert2": "^11.26.3",
    "validator": "^13.11.0"
  }
}
