<?xml version="1.0"?>
<ruleset name="NyalifeHMS">
    <description>Custom PHPCS ruleset for Nyalife HMS (allows non-namespaced classes)</description>
    
    <!-- Include PSR-12 standard but exclude namespace requirement -->
    <rule ref="PSR12">
        <!-- Exclude namespace requirement (PSR-1 rule) since this is a legacy codebase -->
        <exclude name="PSR1.Classes.ClassDeclaration.MissingNamespace"/>
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
    </rule>
    
    <!-- Check for other important PSR-12 rules -->
    <rule ref="PSR12.Files.FileHeader"/>
    <rule ref="PSR12.Classes.ClassInstantiation"/>
    <rule ref="PSR12.ControlStructures"/>
    <rule ref="PSR12.Functions"/>
    <rule ref="PSR12.Keywords"/>
    <rule ref="PSR12.Operators"/>
    <rule ref="PSR12.Properties"/>
    
    <!-- Exclude line length warnings (too many) -->
    <rule ref="Generic.Files.LineLength">
        <exclude-pattern>*</exclude-pattern>
    </rule>
</ruleset>

